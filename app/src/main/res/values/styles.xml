<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 主题 -->
    <style name="Theme.PandaCarLauncher" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.PandaCarLauncher.Home" parent="Theme.PandaCarLauncher">
        <item name="android:windowBackground">@color/home_background</item>
    </style>

    <style name="Theme.PandaCarLauncher.Night" parent="Theme.PandaCarLauncher">
        <item name="android:windowBackground">@color/night_background</item>
        <item name="colorPrimary">@color/night_primary</item>
    </style>

    <!-- 卡片样式 -->
    <style name="CardStyle">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <style name="CardStyle.Large">
        <item name="cardCornerRadius">@dimen/card_corner_radius_large</item>
    </style>

    <style name="CardStyle.Small">
        <item name="cardCornerRadius">@dimen/card_corner_radius_small</item>
    </style>

    <!-- 按钮样式 -->
    <style name="ButtonStyle.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textSize">@dimen/text_size_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
    </style>

    <style name="ButtonStyle.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textSize">@dimen/text_size_button</item>
        <item name="android:textColor">@color/primary</item>
        <item name="strokeColor">@color/primary</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
    </style>

    <style name="ButtonStyle.Icon" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="iconTint">@color/text_primary</item>
        <item name="iconSize">@dimen/icon_size_large</item>
    </style>

    <!-- 文字样式 -->
    <style name="TextStyle.Title">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Subtitle">
        <item name="android:textSize">@dimen/text_size_subtitle</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextStyle.Body">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextStyle.Caption">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextStyle.Large">
        <item name="android:textSize">@dimen/text_size_large</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- 搜索框样式 -->
    <style name="SearchViewStyle">
        <item name="android:background">@drawable/bg_search</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:hint">@string/search_hint</item>
        <item name="android:textColorHint">@color/text_hint</item>
    </style>

    <!-- 滑块样式 -->
    <style name="SeekBarStyle" parent="Widget.AppCompat.SeekBar">
        <item name="android:progressTint">@color/primary</item>
        <item name="android:thumbTint">@color/primary</item>
    </style>

    <!-- 开关样式 -->
    <style name="SwitchStyle" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="trackTint">@color/switch_track</item>
        <item name="thumbTint">@color/switch_thumb</item>
    </style>

    <!-- 标签样式 -->
    <style name="ChipStyle" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textSize">@dimen/text_size_caption</item>
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="android:textColor">@color/chip_text</item>
    </style>

    <!-- 列表项样式 -->
    <style name="ListItemStyle">
        <item name="android:padding">@dimen/item_padding</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <!-- Dock样式 -->
    <style name="DockItemStyle">
        <item name="android:padding">@dimen/dock_item_padding</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">@dimen/text_size_small</item>
        <item name="android:textColor">@color/dock_text</item>
    </style>

    <!-- 对话框样式 -->
    <style name="DialogStyle" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="android:background">@color/dialog_background</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>
</resources>

    <!-- Text Styles -->
    <style name="TextStyle">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextStyle.Title">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextStyle.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
